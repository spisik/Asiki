= Исходный код программы
В исходном коде приводится полный исходный код вашей программы.

Код на ассемблере:
```asm
.global _start
.data
a: .quad 0
b: .quad 0
c: .quad 0
input_str: .asciz "%lu%lu%lu"
output_str: .asciz "Output value: %lu\n"
.text
_start: 
    movq %rsp, %rbp                
    subq $32, %rsp                 
    andq $-16, %rsp                
    leaq input_str(%rip), %rdi     
    movq $a, %rsi                  
    movq $b, %rdx                 
    movq $c, %rcx                  
    call scanf

    movq (a), %rdi 
    movq (b), %rbx 
    movq (c), %rax 

    addq %rdi, %rbx 
    mul %rax 
    movq %rax, %rdi 
    movq %rbx, %rax 
    mul %rax 
    div %rdi 

    leaq  output_str(%rip), %rdi   
    movq %rax, %rsi                
    xor %eax, %eax                 
    call printf                    
    movq %rbp, %rsp                
    movq $0, %rdi                  
    movq $60, %rax                 
    syscall
```

